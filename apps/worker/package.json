{
  "name": "@tip/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@tip/contracts": "workspace:*",
    "@tip/shared": "workspace:*",
    "@tip/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.908.0",
    "@prisma/client": "^6.8.2",
    "bullmq": "^5.63.0",
    "redis": "^5.8.2",
    "sharp": "^0.34.5"
  },
  "scripts": {
    "dev": "node --import tsx src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist"
  }
