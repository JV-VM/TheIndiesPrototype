{
  "name": "@tip/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist",
    "prisma:generate": "XDG_CACHE_HOME=${XDG_CACHE_HOME:-/tmp/prisma-cache} prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "XDG_CACHE_HOME=${XDG_CACHE_HOME:-/tmp/prisma-cache} prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "XDG_CACHE_HOME=${XDG_CACHE_HOME:-/tmp/prisma-cache} prisma db seed --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@tip/contracts": "workspace:*",
    "@tip/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.908.0",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.2",
    "cookie": "^1.0.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "redis": "^5.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.2",
    "prisma": "^6.8.2"
  }
}
