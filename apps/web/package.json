{
  "name": "@tip/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@tip/contracts": "workspace:*",
    "@tip/shared": "workspace:*",
    "@tip/types": "workspace:*"
  },
  "scripts": {
    "dev": "node --import tsx src/dev-server.ts",
    "start": "node dist/dev-server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  }
}
