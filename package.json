{
  "name": "theindiesprototype",
  "version": "0.1.0",
  "private": true,
  "description": "Distributed prototype platform for creator asset workflows.",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^20.17.46",
    "eslint": "^9.27.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
}
