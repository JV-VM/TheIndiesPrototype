NODE_ENV=production

# Public network
TIP_PUBLIC_HTTP_PORT=80
TIP_PUBLIC_HOST=tip.example.com
TIP_WEB_PUBLIC_ORIGIN=https://tip.example.com
TIP_API_PUBLIC_ORIGIN=https://tip.example.com/api
TIP_API_PUBLIC_WS_ORIGIN=wss://tip.example.com/api

# Private infrastructure ports
TIP_POSTGRES_PORT=15432
TIP_REDIS_PORT=16379
TIP_MINIO_CONSOLE_PORT=19001

# Service configuration
TIP_POSTGRES_DB=tip
TIP_POSTGRES_USER=tip
TIP_POSTGRES_PASSWORD=replace-with-strong-password
TIP_MINIO_ACCESS_KEY=tipminio
TIP_MINIO_SECRET_KEY=replace-with-strong-minio-secret
TIP_MINIO_BUCKET=tip-assets
TIP_MINIO_REGION=us-east-1
WORKER_CONCURRENCY=2
WORKER_HEALTH_PORT=3002
UPLOAD_MAX_BYTES=26214400
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-second-long-random-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
